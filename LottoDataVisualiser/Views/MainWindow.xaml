                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.WinningNumbersText, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.BonusNumbersText, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.RawResponse, Mode=OneWay}" Width="auto" Height="auto"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>
            <!--Ekstra Pensja-->
            <TabItem Header="Ekstra Pensja">
                <Border Grid.Row="1" Margin="8" Background="#FFF5F5F5" CornerRadius="4">
                    <ScrollViewer>
                        <StackPanel x:Name="EkstraPensjaStackPanel" Margin="12" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.GameName, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.DrawDate, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.WinningNumbersText, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.BonusNumbersText, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.RawResponse, Mode=OneWay}" Width="auto" Height="auto"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>
            <!--Ekstra Premia-->
            <TabItem Header="Ekstra Premia">
                <Border Grid.Row="1" Margin="8" Background="#FFF5F5F5" CornerRadius="4">
                    <ScrollViewer>
                        <StackPanel x:Name="EkstraPremiaStackPanel" Margin="12" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.GameName, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.DrawDate, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.WinningNumbersText, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.BonusNumbersText, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.RawResponse, Mode=OneWay}" Width="auto" Height="auto"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>
            <!--Szybkie 600-->
            <TabItem Header="Szybkie 600">
                <Border Grid.Row="1" Margin="8" Background="#FFF5F5F5" CornerRadius="4">
                    <ScrollViewer>
                        <StackPanel x:Name="Szybkie600StackPanel" Margin="12" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.GameName, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.DrawDate, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.WinningNumbersText, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.BonusNumbersText, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.RawResponse, Mode=OneWay}" Width="auto" Height="auto"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>
            <!--Zakłady Specjalne-->
            <TabItem Header="Zakłady Specjalne">
                <Border Grid.Row="1" Margin="8" Background="#FFF5F5F5" CornerRadius="4">
                    <ScrollViewer>
                        <StackPanel x:Name="ZakładySpecjalneStackPanel" Margin="12" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.GameName, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.DrawDate, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.WinningNumbersText, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.BonusNumbersText, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.RawResponse, Mode=OneWay}" Width="auto" Height="auto"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

        </TabControl>

        <!--StackPanel-->
        

        <!--przyciski w dole-->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="8">
            <Button x:Name="OkButton" Width="80" Height="30" Content="OK" Margin="0,0,8,0"/>
            <Button x:Name="ApplyButton" Width="80" Height="30" Content="Apply" Margin="0,0,8,0"/>
            <Button x:Name="CancelButton" Width="80" Height="30" Content="Cancel"/>
        </StackPanel>

    </Grid>
</Window>
