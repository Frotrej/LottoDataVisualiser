<Window x:Class="LottoApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LottoApp"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <!--definicja siatki-->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!--zakładki u góry-->
        <TabControl Grid.Row="0" TabStripPlacement="Top" Margin="8">
            <!--LOTTO-->
            <TabItem Header="Lotto" >
                <Border Grid.Row="1" Margin="8" Background="#FFF5F5F5" CornerRadius="4">
                    <ScrollViewer>
                        <StackPanel x:Name="LottoStackPanel" Margin="12" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.DrawDate , Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.DrawDate, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.WinningNumbersText, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.BonusNumbersText, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.RawResponse, Mode=OneWay}" Width="auto" Height="auto"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>
            <!--EURO JACKPOT-->
            <TabItem Header="Euro Jackpot">
                <Border Grid.Row="1" Margin="8" Background="#FFF5F5F5" CornerRadius="4">
                    <ScrollViewer>
                        <StackPanel x:Name="EuroStackPanel" Margin="12" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.GameName, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.DrawDate, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.WinningNumbersText, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.BonusNumbersText, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.RawResponse, Mode=OneWay}" Width="auto" Height="auto"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>
            <!--Multi Multi-->
            <TabItem Header="Multi Multi">
                <Border Grid.Row="1" Margin="8" Background="#FFF5F5F5" CornerRadius="4">
                    <ScrollViewer>
                        <StackPanel x:Name="MultiMultiStackPanel" Margin="12" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.GameName, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.DrawDate, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.WinningNumbersText, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.BonusNumbersText, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.RawResponse, Mode=OneWay}" Width="auto" Height="auto"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>
            <!--Mini Lotto-->
            <TabItem Header="Mini Lotto">
                <Border Grid.Row="1" Margin="8" Background="#FFF5F5F5" CornerRadius="4">
                    <ScrollViewer>
                        <StackPanel x:Name="MiniLottoStackPanel" Margin="12" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.GameName, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.DrawDate, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.WinningNumbersText, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.BonusNumbersText, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.RawResponse, Mode=OneWay}" Width="auto" Height="auto"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>
            <!--Kaskada-->
            <TabItem Header="Kaskada">
                <Border Grid.Row="1" Margin="8" Background="#FFF5F5F5" CornerRadius="4">
                    <ScrollViewer>
                        <StackPanel x:Name="KaskadaStackPanel" Margin="12" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.GameName, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.DrawDate, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.WinningNumbersText, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.BonusNumbersText, Mode=OneWay}" Width="auto" Height="auto"/>
                            <TextBox TextWrapping="Wrap" Text="{Binding LottoResult.RawResponse, Mode=OneWay}" Width="auto" Height="auto"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>
            <!--Keno-->
